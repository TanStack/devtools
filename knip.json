{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["@faker-js/faker"],
  "ignoreWorkspaces": ["examples/**", "e2e/**"],
  "ignore": ["**/bin/intent.js"],
  "workspaces": {
    ".": {
      "entry": ["scripts/generate-docs.ts", "scripts/verify-links.ts"]
    },
    "packages/devtools-a11y": {
      "ignoreDependencies": ["solid-js", "@angular/core"]
    },

    "packages/devtools-utils": {
      "ignoreDependencies": ["react", "solid-js", "svelte", "@types/react"],
      "entry": [
        "**/vite.config.solid.ts",
        "**/src/solid/**",
        "**/vite.config.svelte.ts",
        "**/src/svelte/**"
      ],
      "project": [
        "**/vite.config.solid.ts",
        "**/src/solid/**",
        "**/vite.config.svelte.ts",
        "**/src/svelte/**"
      ]
    },
    "packages/devtools-ui": {
      "entry": ["**/tests/**/*.ts"]
    },
    "packages/solid-devtools": {
      "ignore": ["**/core.tsx"]
    },
    "packages/angular-devtools": {
      "ignoreDependencies": ["tslib"],
      "entry": ["provider/**/*.ts", "src/**/*.ts"]
    }
  }
}
