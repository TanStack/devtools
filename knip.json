{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": ["@faker-js/faker"],
  "ignoreWorkspaces": ["examples/**"],
  "workspaces": {
    "packages/devtools-utils": {
      "ignoreDependencies": ["react", "solid-js", "@types/react"],
      "entry": ["**/vite.config.solid.ts", "**/src/solid/**", "**/vite.config.svelte.ts", "**/src/svelte/**"],
      "project": ["**/vite.config.solid.ts", "**/src/solid/**", "**/vite.config.svelte.ts", "**/src/svelte/**"]
    },
    "packages/devtools-ui": {
      "entry": ["**/tests/**/*.ts"]
    },
    "packages/solid-devtools": {
      "ignore": ["**/core.tsx"]
    }
  }
}
